# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/hostel_finder
# For production (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hostel_finder?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Frontend URL (for CORS & password reset links)
FRONTEND_URL=http://localhost:3000

# Cloudinary Configuration (required for image uploads)
# Sign up at https://cloudinary.com - free tier includes 25GB
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP Configuration for Email (Forgot Password - Optional)
# For Gmail: 
#   - Enable 2-Step Verification at https://myaccount.google.com/security
#   - Generate App Password at https://myaccount.google.com/apppasswords
#   - Use the 16-character app password as SMTP_PASSWORD
# SMTP_EMAIL=your_gmail@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
